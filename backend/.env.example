# Optional: enables live World Cup fixture/result ingestion from football-data.org.
FOOTBALL_DATA_API_KEY=

# Optional: enables API-Football squads, player statistics, and lineups.
API_FOOTBALL_KEY=

# Optional: current World Cup 2026 player statistics and ratings.
KICKOFF_API_KEY=

# Optional: enables the OpenAI-powered analyst. Without it, a deterministic
# analyst explains the same model facts locally.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Free optional analyst alternative. Set LLM_PROVIDER=openrouter to use it.
LLM_PROVIDER=openai
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/free

# Optional: hosted Postgres + authentication for a public leaderboard.
# Keep the service-role key on the FastAPI server only; never expose it in the browser.
DATABASE_URL=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
